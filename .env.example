# Postgres
POSTGRES_USER=supplytracker
POSTGRES_PASSWORD=supplytracker
POSTGRES_DB=supplytracker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://supplytracker:supplytracker@postgres:5432/supplytracker

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
ENVIRONMENT=development
# REQUIRED: set a strong random value before running with sync endpoints exposed
SYNC_BEARER_TOKEN=

# Data sources
PORTWATCH_BASE_URL=https://portwatch.imf.org/api
PORTWATCH_RATE_LIMIT_PER_MINUTE=60
# REQUIRED for FRED collector
FRED_API_KEY=
FRED_SERIES=DCOILBRENTEU,DCOILWTICO,DGS10,PPIACO
FBX_SOURCE_URL=
WCI_SOURCE_URL=
BUNKER_PORTS=SGSIN,AEFJR,NLRTM
BUNKER_FUEL_TYPES=VLSFO,MGO
# News feed (GNews API — https://gnews.io)
# REQUIRED for news collection
GNEWS_API_KEY=
NEWS_FETCH_ENABLED=true
NEWS_MAX_ITEMS_PER_ENTITY=30

# LLM (DashScope Qwen, OpenAI-compatible)
# REQUIRED for LLM features
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PRIMARY_MODEL=qwen-plus
QWEN_FALLBACK_MODEL=qwen-turbo
LLM_REASONING_ENABLED=false
LLM_REQUEST_TIMEOUT_S=60
DECISION_BRIEF_CACHE_TTL_S=3600
CHAT_RATE_LIMIT_PER_5MIN=20

# Mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025

# Frontend
VITE_API_BASE_URL=http://localhost:8000
# Optional: set to enable the Sync button on port/chokepoint detail pages
# VITE_SYNC_BEARER_TOKEN=
